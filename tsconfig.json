{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "outDir": "out",
    "rootDir": "src",
    "sourceMap": true,
    "strict": false,
    "noImplicitOverride": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["node", "vscode"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["out", "node_modules", "test"]
}

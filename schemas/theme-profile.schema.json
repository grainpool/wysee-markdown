{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wysee MD Theme Profile",
  "type": "object",
  "required": ["id", "name", "selectorStyles"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "selectorStyles": { "type": "object", "additionalProperties": { "type": "string" } },
    "previewOnlyStyles": { "type": "object", "additionalProperties": { "type": "string" } },
    "printOnlyStyles": { "type": "object", "additionalProperties": { "type": "string" } },
    "exportClassName": { "type": "string" },
    "pageProfileId": { "type": "string" }
  },
  "additionalProperties": false
}

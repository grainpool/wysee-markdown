{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wysee MD Page Profile",
  "type": "object",
  "required": ["id", "name", "format", "landscape", "marginTop", "marginRight", "marginBottom", "marginLeft", "codeBlocks", "images"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "format": { "type": "string", "enum": ["Letter", "Legal", "A4", "A5", "Tabloid", "Custom"] },
    "width": { "type": "string" },
    "height": { "type": "string" },
    "landscape": { "type": "boolean" },
    "marginTop": { "type": "string" },
    "marginRight": { "type": "string" },
    "marginBottom": { "type": "string" },
    "marginLeft": { "type": "string" },
    "codeBlocks": {
      "type": "object",
      "required": ["wrap"],
      "properties": { "wrap": { "type": "boolean" } },
      "additionalProperties": false
    },
    "images": {
      "type": "object",
      "required": ["defaultAlign", "maxWidth"],
      "properties": {
        "defaultAlign": { "type": "string", "enum": ["left", "center", "right"] },
        "maxWidth": { "type": "string" }
      },
      "additionalProperties": false
    },
    "columns": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "count": { "type": "integer", "enum": [1, 2, 3] },
        "gap": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
